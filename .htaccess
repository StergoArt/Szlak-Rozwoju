<IfModule mod_headers.c>
    # Content Security Policy
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://meet.jit.si/external_api.js; style-src 'self'; font-src 'self'; img-src 'self' data: https:; connect-src 'self' https://krrabwmlzalibufwdlpv.supabase.co wss://krrabwmlzalibufwdlpv.supabase.co https://api.emailjs.com; frame-src https://meet.jit.si; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests;"

    # Clickjacking protection
    Header set X-Frame-Options "DENY"

    # MIME type sniffing protection
    Header set X-Content-Type-Options "nosniff"

    # Force HTTPS (HSTS)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Referrer policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions policy
    Header set Permissions-Policy "geolocation=(), microphone=(self), camera=(self), accelerometer=(), gyroscope=(), magnetometer=(), usb=(), payment=()"
</IfModule>

# --- GZIP / Deflate Compression ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# --- Cache Control ---
<IfModule mod_headers.c>
    # HTML: no cache (zapobiega stale state po deployu)
    <FilesMatch "\.(html)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # Static assets: aggressive cache (1 year, immutable)
    <FilesMatch "\.(woff2|png|webp|ico|jpg|jpeg|svg)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # JS/CSS: long cache (1 month)
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>

    # XML (sitemap): short cache
    <FilesMatch "\.(xml)$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>
</IfModule>

# --- URL Canonicalization ---
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Force non-www (canonical: szlak-rozwoju.pl)
    RewriteCond %{HTTP_HOST} ^www\.szlak-rozwoju\.pl$ [NC]
    RewriteRule ^ https://szlak-rozwoju.pl%{REQUEST_URI} [L,R=301]

    DirectoryIndex index.html
</IfModule>

# --- Prevent directory listing ---
Options -Indexes

# --- Block hidden directories (.git, .svn, etc.) ---
RedirectMatch 404 /\.git

# --- Block access to sensitive files ---
<FilesMatch "\.(md|txt|json|gitignore|sql|env|bak|backup|swp|swo|key|pem|log|orig|conf)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Allow robots.txt and sitemap.xml
<Files "robots.txt">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>
<Files "sitemap.xml">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>
